rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE UTILITIES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'binugede@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY SCHEMAS & VALIDATION ---
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.plan is string &&
             data.plan in ['Free', 'Pro', 'Enterprise'] &&
             data.credits is number &&
             (!data.keys().contains('customGeminiKey') || data.customGeminiKey is string) &&
             (!data.keys().contains('displayName') || data.displayName is string) &&
             data.isAdmin is bool;
    }

    function isValidConversation(data) {
      return data.id is string &&
             data.userId is string &&
             data.app is string &&
             data.tone is string &&
             data.tone in ['casual', 'professional', 'executive'] &&
             data.original is string && data.original.size() <= 5000 &&
             data.rewritten is string && data.rewritten.size() <= 8000;
    }

    function isValidTransaction(data) {
      return data.id is string &&
             data.userId is string &&
             data.email is string &&
             data.plan is string &&
             data.amount is number &&
             data.creditsAdded is number;
    }

    // --- COLLECTIONS ---

    // 1. Users Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming()) && 
                      incoming().uid == request.auth.uid &&
                      incoming().isAdmin == false && // Prevent self-elevation on create
                      incoming().credits <= 500;    // Prevent self-credit allocation on signup
                      
      allow update: if (isOwner(userId) && (
                      // Only allow updating display name, api key, or timestamp
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'customGeminiKey', 'updatedAt']) &&
                      incoming().uid == existing().uid &&
                      incoming().email == existing().email &&
                      incoming().plan == existing().plan &&
                      incoming().credits == existing().credits &&
                      incoming().isAdmin == existing().isAdmin
                    )) || isAdmin();

      allow delete: if isAdmin();

      // 2. Saved Conversations (Subcollection)
      match /saved_conversations/{conversationId} {
        allow get, list, delete: if isOwner(userId);
        
        allow create: if isOwner(userId) && 
                        isValidId(conversationId) && 
                        isValidConversation(incoming()) && 
                        incoming().userId == request.auth.uid;
                        
        allow update: if isOwner(userId) && 
                        isValidConversation(incoming()) && 
                        incoming().userId == existing().userId;
      }
    }

    // 3. Billing & Purchase Ledger
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                      isValidId(transactionId) && 
                      isValidTransaction(incoming()) && 
                      incoming().userId == request.auth.uid;
                      
      // Transactions are immutable logs
      allow update, delete: if false;
    }

    // 4. Admin Roll Explicit List
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
